{
  "name": "create-vforge-app",
  "version": "1.0.0",
  "description": "VForge CLI to generate production-ready Next.js boilerplate projects",
  "author": "Visiontillion Labs",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/visiontillion-labs/forge.git",
    "directory": "cli"
  },
  "keywords": [
    "nextjs",
    "boilerplate",
    "generator",
    "react",
    "typescript",
    "cli",
    "create-app"
  ],
  "bin": {
    "create-vforge-app": "./dist/index.mjs"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts --format esm --watch",
    "start": "node dist/index.mjs",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.0.0",
    "chalk": "^5.3.0",
    "commander": "^13.0.0",
    "fs-extra": "^11.2.0",
    "ora": "^8.1.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20",
    "tsup": "^8.0.0",
    "typescript": "^5"
  }
}
